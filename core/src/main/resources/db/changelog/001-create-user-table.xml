<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="create-user-table" author="Artash Shaghoyan">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="user" schemaName="agro_trade"/>
            </not>
        </preConditions>

        <createTable tableName="user" schemaName="agro_trade">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="surname" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="gender" type="varchar(10)">
                <constraints nullable="false"/>
            </column>
            <column name="username" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="password" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="phone_number" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="verification_code" type="varchar(10)">
                <constraints nullable="true"/>
            </column>
            <column name="verification_expiration" type="timestamp">
                <constraints nullable="true"/>
            </column>
            <column name="active" type="bool" defaultValue="false">
                <constraints nullable="false"/>
            </column>
            <column name="birth_date" type="date">
                <constraints nullable="true"/>
            </column>
            <column name="address" type="varchar(255)">
                <constraints nullable="true"/>
            </column>
            <column name="document_id" type="BIGINT">
                <constraints nullable="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="user-table-rollback" author="Artash Shaghoyan">
        <rollback>
            <dropTable
                    tableName="user"
                    schemaName="agro_trade"
                    cascadeConstraints="true"/>
        </rollback>
    </changeSet>

</databaseChangeLog>