<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="create-news-table" author="Grisha">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists schemaName="agro_trade" tableName="news"/>
            </not>
        </preConditions>

        <createTable schemaName="agro_trade" tableName="news">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="title" type="varchar(100)">
                <constraints nullable="false"/>
            </column>

            <column name="context" type="text">
                <constraints nullable="false"/>
            </column>

            <column name="author_id" type="bigint">
                <constraints nullable="false"/>
            </column>

            <column name="create_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableSchemaName="agro_trade"
                baseTableName="news"
                baseColumnNames="author_id"
                constraintName="fk_news_user"
                referencedTableSchemaName="agro_trade"
                referencedTableName="user"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="news-table-rollback" author="Grisha Grigoryan">
        <rollback>
            <dropTable
                    tableName="news"
                    schemaName="agro_trade"
                    cascadeConstraints="true"/>
        </rollback>
    </changeSet>
</databaseChangeLog>